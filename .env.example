# SmartKash backend environment template
# Copy this file to your local environment file when implementation starts.
# Never commit real secrets.

DATABASE_URL=jdbc:postgresql://localhost:5432/smartkash_db
DATABASE_USERNAME=smartkash_admin
DATABASE_PASSWORD=replace-with-your-local-database-password
JWT_SECRET=replace-with-a-long-random-development-secret

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-test-key\n-----END PRIVATE KEY-----\n"

FCM_ENABLED=false
APP_ENV=local
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
